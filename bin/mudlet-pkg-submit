#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

FORK_REPO="gesslar/mudlet-package-repository"
UPSTREAM_REPO="Mudlet/mudlet-package-repository"

# Read mfile
MFILE="$PROJECT_DIR/mfile"
if [[ ! -f "$MFILE" ]]; then
  echo "Error: mfile not found at $MFILE"
  exit 1
fi

PACKAGE=$(jq -r '.package' "$MFILE")
TITLE=$(jq -r '.title' "$MFILE")
VERSION=$(jq -r '.version' "$MFILE")
AUTHOR=$(jq -r '.author' "$MFILE")

# Check build
BUILT_FILE="$PROJECT_DIR/build/.built"
if [[ ! -f "$BUILT_FILE" ]]; then
  echo "Error: build/.built not found — run muddy first"
  exit 1
fi

CREATED=$(cat "$BUILT_FILE" | tr -d '[:space:]')

MPACKAGE="$PROJECT_DIR/build/${PACKAGE}.mpackage"
if [[ ! -f "$MPACKAGE" ]]; then
  echo "Error: $MPACKAGE not found"
  exit 1
fi

# Read README for PR description
README=""
if [[ -f "$PROJECT_DIR/README.md" ]]; then
  README=$(cat "$PROJECT_DIR/README.md")
fi

# Branch name matching Mudlet convention
BRANCH_SAFE=$(echo "$CREATED" | sed 's/[^a-zA-Z0-9]/-/g')
BRANCH="package-upload/${PACKAGE}-${BRANCH_SAFE}"

echo "Package: $PACKAGE"
echo "Version: $VERSION"
echo "Author:  $AUTHOR"
echo "Branch:  $BRANCH"
echo ""

# Clone or update the fork
FORK_DIR=$(mktemp -d)
trap 'rm -rf "$FORK_DIR"' EXIT

echo "Cloning fork..."
gh repo clone "$FORK_REPO" "$FORK_DIR" -- --depth 1

cd "$FORK_DIR"

# Sync fork with upstream
echo "Syncing fork with upstream..."
gh repo sync "$FORK_REPO" --source "$UPSTREAM_REPO" --branch main

git pull --ff-only origin main

# Create branch
git checkout -b "$BRANCH"

# Copy the mpackage
cp "$MPACKAGE" "packages/${PACKAGE}.mpackage"

# Commit and push
git add "packages/${PACKAGE}.mpackage"
git commit -m "Add package: ${PACKAGE}.mpackage"
git push -u origin "$BRANCH"

# Create PR
PR_BODY="$(cat <<EOF
Package information:
- Name: ${PACKAGE}
- Title: ${TITLE}
- Version: ${VERSION}
- Author: ${AUTHOR}
- Created: ${CREATED}

---
${README}
EOF
)"

PR_URL=$(gh pr create \
  --repo "$UPSTREAM_REPO" \
  --title "Add package: ${PACKAGE}.mpackage" \
  --body "$PR_BODY")

echo ""
echo "PR created: $PR_URL"
